# ── POSTGRESQL (Metadata & Config DB)
POSTGRES_USER=agrisense_admin
POSTGRES_PASSWORD=agrisense_secure_pass_2026
POSTGRES_DB=agrisense_meta

# ── INFLUXDB v2 (Time-series Sensor DB)
INFLUX_ADMIN_USER=agrisense_admin
INFLUX_ADMIN_PASS=influx_secure_pass_2026
INFLUX_ORG=AgriSense_Corp
INFLUX_BUCKET=terra_metrics
# Token must be at least 32 chars:
INFLUX_TOKEN=vLdqwxyz_REPLACE_ME_SUPER_SECRET_TOKEN_12345==

# ── ORCHESTRATOR / TELEGRAM BOT
